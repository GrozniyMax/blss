          "name": "Update order status",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/order/{{orderId}}/status/next",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "order",
                "{{orderId}}",
                "status",
                "next"
              ]
            }
          }
        }
