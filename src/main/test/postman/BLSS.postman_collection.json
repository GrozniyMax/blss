      "name": "Order",
      "item": [
        {
          "name": "Create order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300 && pm.response.text()) {",
                  "  const body = pm.response.json();",
                  "  pm.globals.set('orderId', body.data.orderId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"owner\": \"{{ownerId}}\",\n  \"location\": \"{{locationId}}\",\n  \"productIds\": [\n    \"{{productId1}}\",\n    \"{{productId2}}\"\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/order/create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "order",
                "create"
              ]
            }
          }
        },
        {
          "name": "Get order by id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.data.positions && body.data.positions.length) {",
                  "    pm.globals.set('orderItemId', body.data.positions[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/order/{{orderId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "order",
                "{{orderId}}"
              ]
            }
          }
        },
